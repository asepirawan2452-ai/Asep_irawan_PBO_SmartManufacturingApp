@model IEnumerable<SmartManufacturingApp.Models.ProductionOrder>

@{
    ViewData["Title"] = "Production Order";
}

<partial name="_Alert" />

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white d-flex justify-content-between">

            <h4>Production Order</h4>

            <a asp-action="Create"
               class="btn btn-light">

                + New Work Order

            </a>

        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover">

                <thead class="table-dark">

                    <tr>

                        <th>WO Number</th>

                        <th>Date</th>

                        <th>Machine</th>

                        <th>Operator</th>

                        <th>Status</th>

                        <th width="220">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach(var item in Model)
                    {
                        <tr>

                            <td>@item.WorkOrderNumber</td>

                            <td>@item.ProductionDate.ToString("dd/MM/yyyy")</td>

                            <td>@item.Machine?.MachineName</td>

                            <td>@item.OperatorEmployee?.FullName</td>

                            <td>@item.Status</td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">

                                    Detail

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">

                                    Delete

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>