@model SmartManufacturingApp.ViewModels.ProductionOrderViewModel

@{
    ViewData["Title"] = "Create Production Order";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h4>Create Production Order</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- HEADER -->
                <div class="mb-3">
                    <label asp-for="WorkOrderNumber"></label>
                    <input asp-for="WorkOrderNumber" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="ProductionDate"></label>
                    <input asp-for="ProductionDate" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Machine</label>
                    <select asp-for="MachineId" asp-items="Model.Machines" class="form-select">
                        <option value="">-- Select Machine --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Operator</label>
                    <select asp-for="OperatorEmployeeId" asp-items="Model.Operators" class="form-select">
                        <option value="">-- Select Operator --</option>
                    </select>
                </div>

                <!-- 🔥 DETAIL PRODUK -->
                <h5 class="mt-4">Detail Produk</h5>

                <table class="table table-bordered" id="detailTable">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Target Qty</th>
                            <th width="80">#</th>
                        </tr>
                    </thead>
                    <tbody>

                        @for (int i = 0; i < Model.Details.Count; i++)
                        {
                            <tr>
                                <td>
                                    <select asp-for="Details[i].ProductId"
                                            asp-items="Model.Products"
                                            class="form-select">
                                        <option value="">-- Select Product --</option>
                                    </select>
                                </td>

                                <td>
                                    <input asp-for="Details[i].TargetQty"
                                           class="form-control" />
                                </td>

                                <td>
                                    <button type="button"
                                            class="btn btn-danger btn-sm removeRow">
                                        X
                                    </button>
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>

                <button type="button" class="btn btn-success mb-3" id="addRow">
                    + Add Product
                </button>

                <br />

                <button class="btn btn-primary">
                    Save
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        let rowIndex = @Model.Details.Count;

        document.getElementById("addRow").addEventListener("click", function () {

            let table = document.querySelector("#detailTable tbody");

            let newRow = `
            <tr>
                <td>
                    <select name="Details[${rowIndex}].ProductId" class="form-select">
                        @foreach (var p in Model.Products)
                        {
                            <option value="@p.Value">@p.Text</option>
                        }
                    </select>
                </td>

                <td>
                    <input name="Details[${rowIndex}].TargetQty" class="form-control" />
                </td>

                <td>
                    <button type="button" class="btn btn-danger btn-sm removeRow">X</button>
                </td>
            </tr>
            `;

            table.insertAdjacentHTML("beforeend", newRow);

            rowIndex++;
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("removeRow")) {
                e.target.closest("tr").remove();
            }
        });
    </script>
}
