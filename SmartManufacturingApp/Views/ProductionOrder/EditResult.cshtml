@model SmartManufacturingApp.ViewModels.ProductionOrderViewModel

<form asp-action="EditResult" method="post">
    
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Actual</th>
                <th>Reject</th>
            </tr>
        </thead>

        <tbody>
            @for (int i = 0; i < Model.Details.Count; i++)
            {
                <tr>
                    <!-- WAJIB ADA -->
                    <input type="hidden" asp-for="Details[@i].ProductId" />

                    <td>@Model.Details[i].ProductName</td>

                    <td>
                        <input asp-for="Details[@i].ActualQty" class="form-control" />
                    </td>

                    <td>
                        <input asp-for="Details[@i].RejectQty" class="form-control" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-primary">Update</button>
</form>