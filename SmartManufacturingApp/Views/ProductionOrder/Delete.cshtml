@model SmartManufacturingApp.Models.ProductionOrder

@{
    ViewData["Title"] = "Delete Production Order";
}

<div class="container mt-4">

    <div class="card shadow border-danger">

        <div class="card-header bg-danger text-white">

            <h4>Delete Production Order</h4>

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                <strong>Warning!</strong>

                Apakah Anda yakin ingin menghapus Production Order ini?

            </div>

            <table class="table table-bordered">

                <tr>
                    <th width="220">Work Order</th>
                    <td>@Model.WorkOrderNumber</td>
                </tr>

                <tr>
                    <th>Production Date</th>
                    <td>@Model.ProductionDate.ToString("dd/MM/yyyy")</td>
                </tr>

                <tr>
                    <th>Machine</th>
                    <td>@Model.Machine?.MachineName</td>
                </tr>

                <tr>
                    <th>Operator</th>
                    <td>@Model.OperatorEmployee?.FullName</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>@Model.Status</td>
                </tr>

            </table>

            <form asp-action="Delete" method="post">

                <input asp-for="Id" type="hidden" />

                <button class="btn btn-danger">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>