@model SmartManufacturingApp.Models.OperatorEmployee

@{
    ViewData["Title"] = "Edit Operator";
}

<div class="container mt-4">

<div class="card shadow">

<div class="card-header bg-warning">
<h4>Edit Operator</h4>
</div>

<div class="card-body">

<form asp-action="Edit" method="post">

@Html.AntiForgeryToken()

<input asp-for="Id" type="hidden"/>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="mb-3">

<label asp-for="EmployeeCode"></label>

<input asp-for="EmployeeCode" class="form-control"/>

<span asp-validation-for="EmployeeCode" class="text-danger"></span>

</div>

<div class="mb-3">

<label asp-for="FullName"></label>

<input asp-for="FullName" class="form-control"/>

<span asp-validation-for="FullName" class="text-danger"></span>

</div>

<div class="mb-3">

<label asp-for="Department"></label>

<input asp-for="Department" class="form-control"/>

<span asp-validation-for="Department" class="text-danger"></span>

</div>

<div class="form-check mb-3">

<input asp-for="IsActive" class="form-check-input"/>

<label asp-for="IsActive" class="form-check-label"></label>

</div>

<button type="submit" class="btn btn-warning">
Update
</button>

<a asp-action="Index" class="btn btn-secondary">
Back
</a>

</form>

</div>

</div>

</div>

@section Scripts{
<partial name="_ValidationScriptsPartial"/>
}