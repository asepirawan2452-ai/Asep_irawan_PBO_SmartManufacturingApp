@model IEnumerable<SmartManufacturingApp.ViewModels.ProductionReportViewModel>

@{
    ViewData["Title"] = "Daily Production Report";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <h3>Daily Production Report</h3>

        </div>

        <div class="card-body">

            <form method="get" class="row mb-3">

                <div class="col-md-4">

                    <input type="date"
                           name="date"
                           class="form-control"
                           value="@(((DateTime?)ViewBag.Date)?.ToString("yyyy-MM-dd"))" />

                </div>

                <div class="col-md-auto">

                    <button class="btn btn-primary">

                        Filter

                    </button>

                </div>

            </form>

            <table class="table table-bordered table-striped">

                <thead class="table-dark">

                    <tr>

                        <th>WO</th>

                        <th>Date</th>

                        <th>Machine</th>

                        <th>Operator</th>

                        <th>Product</th>

                        <th>Target</th>

                        <th>Actual</th>

                        <th>Reject</th>

                        <th>Efficiency</th>

                    </tr>

                </thead>

                <tbody>

                @foreach(var item in Model)
                {

                    <tr>

                        <td>@item.WorkOrderNumber</td>

                        <td>@item.ProductionDate.ToShortDateString()</td>

                        <td>@item.MachineName</td>

                        <td>@item.OperatorName</td>

                        <td>@item.ProductName</td>

                        <td>@item.TargetQty</td>

                        <td>@item.ActualQty</td>

                        <td>@item.RejectQty</td>

                        <td>@item.Efficiency %</td>

                    </tr>

                }

                </tbody>

            </table>

        </div>

    </div>

</div>
