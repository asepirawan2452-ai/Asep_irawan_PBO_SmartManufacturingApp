@model SmartManufacturingApp.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-success text-white">
            <h4>Add Product</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- Product Code -->
                <div class="mb-3">
                    <label asp-for="ProductCode" class="form-label"></label>
                    <input asp-for="ProductCode" class="form-control" />
                    <span asp-validation-for="ProductCode" class="text-danger"></span>
                </div>

                <!-- Product Name -->
                <div class="mb-3">
                    <label asp-for="ProductName" class="form-label"></label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <!-- Category -->
                <div class="mb-3">
                    <label asp-for="Category" class="form-label"></label>
                    <input asp-for="Category" class="form-control" />
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <!-- Unit -->
                <div class="mb-3">
                    <label asp-for="Unit" class="form-label"></label>
                    <input asp-for="Unit" class="form-control" />
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>

                <!-- Standard Cost -->
                <div class="mb-3">
                    <label asp-for="StandardCost" class="form-label"></label>
                    <input asp-for="StandardCost"
                           type="number"
                           step="0.01"
                           class="form-control" />
                    <span asp-validation-for="StandardCost" class="text-danger"></span>
                </div>

                <!-- Is Active -->
                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>

                <!-- Buttons -->
                <button type="submit" class="btn btn-success">
                    Save
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
