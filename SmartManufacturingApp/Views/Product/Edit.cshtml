@model SmartManufacturingApp.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning">
            <h4>Edit Product</h4>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                @Html.AntiForgeryToken()

                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="ProductCode"></label>
                    <input asp-for="ProductCode" class="form-control" />
                    <span asp-validation-for="ProductCode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductName"></label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Category"></label>
                    <input asp-for="Category" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Unit"></label>
                    <input asp-for="Unit" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="StandardCost"></label>
                    <input asp-for="StandardCost" class="form-control" />
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive"></label>
                </div>

                <button class="btn btn-warning">
                    Update
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
}