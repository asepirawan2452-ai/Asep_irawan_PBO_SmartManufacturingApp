@model SmartManufacturingApp.Models.Machine

@{
    ViewData["Title"] = "Edit Machine";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-warning">
            <h3>Edit Machine</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-3">

                    <label asp-for="MachineCode" class="form-label"></label>

                    <input asp-for="MachineCode"
                           class="form-control" />

                    <span asp-validation-for="MachineCode"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="MachineName" class="form-label"></label>

                    <input asp-for="MachineName"
                           class="form-control" />

                    <span asp-validation-for="MachineName"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Location" class="form-label"></label>

                    <input asp-for="Location"
                           class="form-control" />

                    <span asp-validation-for="Location"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Status" class="form-label"></label>

                    <select asp-for="Status"
                            asp-items="Html.GetEnumSelectList<SmartManufacturingApp.Models.Enums.MachineStatus>()"
                            class="form-select">
                    </select>

                    <span asp-validation-for="Status"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Temperature" class="form-label"></label>

                    <input asp-for="Temperature"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="SpeedRPM" class="form-label"></label>

                    <input asp-for="SpeedRPM"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="Utilization" class="form-label"></label>

                    <input asp-for="Utilization"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="LastMaintenance" class="form-label"></label>

                    <input asp-for="LastMaintenance"
                           type="date"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="NextMaintenance" class="form-label"></label>

                    <input asp-for="NextMaintenance"
                           type="date"
                           class="form-control" />

                </div>

                <button type="submit"
                        class="btn btn-warning">

                    Update

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Back

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}