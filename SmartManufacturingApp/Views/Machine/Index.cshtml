@model IEnumerable<SmartManufacturingApp.Models.Machine>
@using SmartManufacturingApp.Models.Enums

@{
    ViewData["Title"] = "Machine Management";
}

<div class="container mt-4">

    <partial name="_Alert" />

    <div class="card shadow">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                Machine Management
            </h4>

            <a asp-action="Create" class="btn btn-light">
                + Add Machine
            </a>

        </div>

        <div class="card-body">

            <form method="get" class="row mb-4">

                <div class="col-md-5">

                    <input name="keyword" value="@ViewBag.Keyword" class="form-control"
                           placeholder="Search machine..." />

                </div>

                <div class="col-md-auto">

                    <button class="btn btn-primary">
                        Search
                    </button>

                </div>

                <div class="col-md-auto">

                    <a asp-action="Index" class="btn btn-secondary">
                        Reset
                    </a>

                </div>

            </form>

            @if (!Model.Any())
            {
                <div class="alert alert-warning">
                    Data machine belum tersedia.
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-bordered table-hover align-middle">

                        <thead class="table-dark">

                            <tr>

                                <th>Code</th>
                                <th>Name</th>
                                <th>Location</th>
                                <th>Status</th>
                                <th width="220">Action</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>@item.MachineCode</td>

                                    <td>@item.MachineName</td>

                                    <td>@item.Location</td>

                                    <td>

                                        @if (item.Status == MachineStatus.Running)
                                        {
                                            <span class="badge bg-success">
                                                Running
                                            </span>
                                        }
                                        else if (item.Status == MachineStatus.Idle)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Idle
                                            </span>
                                        }
                                        else if (item.Status == MachineStatus.Maintenance)
                                        {
                                            <span class="badge bg-danger">
                                                Maintenance
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                            Detail
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                            Delete
                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

</div>